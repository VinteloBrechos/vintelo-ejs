<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pedido Confirmado</title>
  <link rel="stylesheet" href="css/pedidoconf.css">
</head>
<body>
  <div class="container">
    <header>
        <nav class="grid">
            <a href="/homecomprador">
              <img src="imagens/seta.png" alt="Seta Voltar">
            </a>
        </nav>
    </header>
    
  <main>
    <section class="oculto-desktop">
    <section class="confirmation-section">
      <div class="illustration">
        <img src="imagens/pedidoconfirmado.png" class="pedidoconf" >
      </div>
      <br>
      <br>
      <h1>Pedido confirmado!</h1>
      <p>Seu pedido foi confirmado, enviaremos um e-mail de confirmação em breve.</p>
      <a href="/minhascompras"><button class="view-orders-button">Ver minhas compras</button></a>
    </section>
    </div>
  </section>

  <section class="oculto-mobile">
    <section class="confirmation">
      <div class="icon-circle">
          <img src="imagens/pedidoconfirmado.png" alt="Ícone de confirmação" class="confirmation-icon">
      </div>
      <h1>Pedido confirmado!</h1>
      <p>Seu pedido foi confirmado, enviaremos um e-mail de confirmação em breve.</p>
      <a href="/minhascompras" class="button">Ver minhas compras</a>
  </section>
  </section>
  </main> 
   <footer>
    <section class="buttons-section">
      <button class="continue-shopping-button">Continue comprando</button>
    </section>
  </footer>
</body>
</html>
