<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sacola</title>
  <link rel="stylesheet" href="css/finalizandocompra.css">
</head>
<body>
  <!-- Header -->
  <header>
    <nav class="grid">
      <a href="/index">
        <img src="imagens/seta.png" alt="Seta Voltar">
      </a>
      <img src="imagens/logo.png" alt="Logo">
      <a href="/carrinho">
        <img src="imagens/carrinho.png" alt="Carrinho">
      </a>
    </nav>
  </header>
   
  <main>
  <!-- Produto Adicionado -->
  <section class="product-section">
    <article class="product-card">
      <img src="imagens/regata branca.png" alt="Vestido Branco Longo" class="product-img">
      <section class="product-info">
        <h3>Regata Branca</h3>
        <p>R$29,99</p>
      </section>
      <button class="delete-product">🗑</button>
    </article>
  </section>

  <!-- Informações do Pedido -->
  <section class="order-info">
    <h4>Informações do pedido</h4>
    <section class="order-details">
      <p>Subtotal</p><p>R$29,99</p>
      <p>Frete</p><p>R$10,00</p>
      <p>Desconto</p><p>R$0,00</p>
      <p><strong>Total</strong></p><p><strong>R$39,99</strong></p>
    </section>
  </section>

  <!-- Cupom de Desconto -->
  <section class="discount-section">
    <h4>Inserir cupom de desconto</h4>
    <form class="discount-input">
      <input type="text" placeholder="Digite o cupom">
      <button class="apply-button">Inserir</button>
    </form>
  </section>

  <!-- Adicionar mais ao carrinho -->
  <section class="suggestions-section">
    <h4>Adicione mais ao carrinho</h4>
    <ul class="product-list">
      <li class="product-suggestion">
        <img src="imagens/conjunto.png" alt="Saia Branca">
        <p>Saia Branca</p>
        <p>R$25,00</p>
      </li>
      <li class="product-suggestion">
        <img src="imagens/saia preta.png" alt="Saia Preta">
        <p>Saia Preta</p>
        <p>R$30,00</p>
      </li>
      <li class="product-suggestion">
        <img src="imagens/saia marrom-2.png" alt="Saia de Veludo">
        <p>Saia de Veludo</p>
        <p>R$25,00</p>
      </li>
      <li class="product-suggestion">
        <img src="imagens/saia rosa brilhante-2.png" alt="Saia Rosa Brilhante">
        <p>Saia Rosa Brilhante</p>
        <p>R$25,00</p>
      </li>
      <li class="product-suggestion">
        <img src="imagens/saia marrom de couro-2.png" alt="Saia de Vinil">
        <p>Saia de Vinil</p>
        <p>R$25,00</p>
      </li>
    </ul>
    <p class="favorites-link">Conferir peças favoritas →</p>
  </section>
</main>
  <!-- Botão Finalizar Compra -->
  <footer>
    <a href="/cadastro"><button class="finalize-button">Finalizar compra</button></a>
  </footer>
</body>
</html>
