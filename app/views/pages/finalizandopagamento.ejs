<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Finalizar Compra</title>
  <link rel="stylesheet" href="css/finalizandopagamento.css">
</head>
<body>
  <div class="container">
    <header>
      <a href="/homecomprador">
        <img src="imagens/seta.png" alt="Seta Voltar">
      </a>
      <h1>Finalizar Compra</h1>
    </header>
    <br>
    <br>
<main>
  <section class="oculto-desktop">
    <section class="content">
      <div class="section">
        <h2>Endereço de entrega</h2>
        <div class="item">
          <img src="imagens/mapa.png" alt="Ícone de localização" class="icon">
          <span>Av. Paulista</span>
          <img src="imagens/check.png" alt="Check" class="check-icon">
        </div>
      </div>

      <div class="section">
        <h2>Forma de pagamento</h2>
        <div class="item payment-option" onclick="selectPayment(this)">
          <img src="imagens/visa.png" alt="Visa" class="icon">
          <span>Adicionar Cartão</span>
          <img src="imagens/erro.png" alt="Erro" class="error-icon">
        </div>
        <div class="item payment-option" onclick="selectPayment(this)">
          <img src="imagens/pix.png" alt="PIX" class="icon">
          <span>PIX</span>
          <img src="imagens/check.png" alt="Check" class="check-icon">
        </div>
        <div class="item payment-option" onclick="selectPayment(this)">
          <img src="imagens/boleto.png" alt="Boleto" class="icon">
          <span>Boleto</span>
          <img src="imagens/check.png" alt="Check" class="check-icon">
        </div>
      </div>
      
      <div class="total">
        <span>Total</span>
        <span>R$59,99</span>
      </div>
    </section>
  </section>

  <!--  parte para desktop-->
  <section class="oculto-mobile">
    <nav class="grid">
      <a href="/index">
        <img src="imagens/logo.png"class="logo">
      </a>

            <!--                                        barra de pesquisa                                              -->
    <section class="search-section">
      <div class="search-container">
        <form class="search-form">
          <button type="button" class="search-icon">
            <img src="imagens/pesquisa.png" alt="Pesquisar">
          </button>
          <input type="text" placeholder="Busque..." required>
          <button type="button" class="mic-icon">
            <img src="imagens/microfone.png" alt="Microfone">
          </button>
        </form>
      </div>
    </section>   
    <script src="/js/script.js"></script>
    <a href="/criarbrecho">
      <img src="imagens/add brecho.png" class="img-grid">
    </a>
    <a href="/sacola">
      <img src="imagens/icone saco.png" class="img-grid">
    </a>
    </nav>
    <div class="sacola-container">
      <h1 class="adicionar">Sacola</h1>
      <div class="sacola-content">
          <div class="produto-card">
              <img src="imagens/vestido branco.png" alt="Vestido branco com decote">
              <div class="produto-info">
                  <h2>Vestido branco com decote</h2>
                  <p>R$49,90</p>
              </div>
              <button class="remove-btn">
                <img src="imagens/lixeira.png" class="lixeira2">
              </button>
          </div>

          <div class="pedido-info">
              <h2>Informações do pedido</h2>
              <div class="pedido-detalhes">
                  <div class="detalhe">
                      <span>Subtotal</span>
                      <span>R$ 49,99</span>
                  </div>
                  <div class="detalhe">
                      <span>Frete</span>
                      <span>R$ 10,00</span>
                  </div>
                  <div class="detalhe">
                      <span>Desconto</span>
                      <span>R$ 0,00</span>
                  </div>
                  <div class="detalhe total">
                      <span>Total</span>
                      <span>R$ 59,99</span>
                  </div>
              </div>
              <div class="cupom">
                  <input type="text" placeholder="Inserir cupom de desconto">
                  <button>Inserir</button>
              </div>
              <a href="/cadastro" ><button class="finalizar-compra">Finalizar Compra</button></a> 
          </div>
      </div>
  </div>

             <!--                                        PRODUTOS OCULTOS                                               -->
             <section class="produtos-ocultos">
                <h1 class="adicionar">Adicione mais à sacola</h1>
                <section class="product-grid">
                  <article class="product-card">
                      <img src="imagens/oculos.png" alt="Óculos de sol">
                      <h2>Óculos de sol</h2>
                      <br>
                      <p class="price">R$12,00</p>
                      <button class="favorite"><img src="imagens/coraçao de fav2.png"></button>
                      <button class="cart"><img src="imagens/sacola.png" class="img-sacola"></button>
                  </article>
          
                  <article class="product-card">
                      <img src="imagens/colar.png" alt="Conjunto 3 colares de prata">
                      <h2>Conjunto 3 cores de prata</h2>
                      <p class="price">R$29,99 <br>ou em 2x R$15,00</p>
                      <button class="favorite"><img src="imagens/coraçao de fav2.png"></button>
                      <button class="cart"><img src="imagens/sacola.png"class="img-sacola"></button>
                  </article>
          
                  <article class="product-card">
                      <img src="imagens/bolsa.png" alt="Bolsa preta com alça dourada">
                      <h2>Bolsa preta com alça dourada</h2>
                      <p class="price">R$20,00 <br>ou em 2x R$10,00</p>
                      <button class="favorite"><img src="imagens/coraçao de fav2.png"></button>
                      <button class="cart"><img src="imagens/sacola.png"class="img-sacola"></button>
                  </article>
          
                  <article class="product-card">
                      <img src="imagens/aneis.png" alt="Anel de prata">
                      <h2>Anel de prata</h2>
                      <br>
                      <p class="price">R$15,00</p>
                      <button class="favorite"><img src="imagens/coraçao de fav2.png"></button>
                      <button class="cart"><img src="imagens/sacola.png"class="img-sacola"></button>
                  </article>
                </section>
              </section>
<!-- Botão Finalizar Compra -->
<a href="/cadastro"><button class="finalize-button2">Finalizar compra</button></a>
<br>
<br>
    </main>
    <section class="oculto-mobile">
    <!--                                                    Rodapé                                                      -->
    <footer class="footer">
      <img src="imagens/logo2.jpeg" alt="Imagem do Rodapé" class="footer-image">
      <div class="social-media">
        <p class="p-footer">Siga nossas redes sociais</p>
        <ul class="social-links">
          <li><a href="https://facebook.com" target="_blank" class="social-link"><img src="imagens/Facebook.png" alt="Facebook"></a></li>
          <li><a href="https://twitter.com" target="_blank" class="social-link"><img src="imagens/Pinterest.png" alt="Pinterest"></a></li>
          <li><a href="https://www.instagram.com/vintelobrechos" target="_blank" class="social-link"><img src="imagens/Instagram.png" alt="Instagram"></a></li>
        </ul>
      </div>
       <p class="copyright">©2024 Vintélo. Todos os direitos reservados.</p>
    </footer>
    </section>
</body>
</html>



</main>
<br>
    <footer>
     <a href="/pedidoconf" class="link-branco"><button class="finalize-button">Finalizar compra</button></a>
    </footer>
  </div>

  <script src="js/script.js"></script>
</body>
</html>
