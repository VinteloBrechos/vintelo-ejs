<!DOCTYPE html>
<html>
  <meta charset="UTF-8">
  <head>
    <title>Categoria</title>
    <link rel="stylesheet" href="css/categorias.css">

  </head>
    <body>

     <header>
        <nav class="grid">
            <a href="/index">
             <img src="imagens/seta.png">
