                  <img src="imagens/vestido pink.png">
                   <p class="legenda">Vestido pink</p>
                   <p class="legenda">R$19,99</p>
                 </li>
               </ul>
   
               <ul class="linha">
                <li class="celula">
                 <img src="imagens/vestido branco.png">
