<!DOCTYPE html>
<html>
  <meta charset="UTF-8">
  <head>
    <title>Vintélo</title>
    <link rel="stylesheet" href="css/estilo.css">
  </head>
  <body>
    <center>
      <div class="discount-banner">
       <span class="highlight"><img-responsiva>10% OFF Na primeira compra</span>
     </div>
     </center>   
     <br>
    <header>
      <nav class="grid">
        <nav class="menu-hamburger">
 
          <input id="menu-hamburguer" type="checkbox" />
          <label for="menu-hamburguer">
            <div class="menu">
            <span class="hamburguer"></span>
            </div>
          </label>
          
          <ul class="menu-hamburguer-elements show">

            <li>
              <a href="#"><img class="logo" src="imagens/logo.png"></a>
            </li>
          
            <li>
              <a href="#"><img class="icone" src="imagens/informaçao da conta.png"></a>
            </li>
            <li>
              <a href="/sacola1"><img class="icone" src="imagens/sacola.png"></a>
            </li>
            <li>
              <a href="#"><img class="icone" src="imagens/minhas compras.png"></a>
            </li>
          
            <li>
              <a href="#"><img class="icone" src="imagens/meus cartoes.png"></a>
            </li>
          
            <li>
              <a href="/favoritos"><img class="icone" src="imagens/icone favoritos.png"></a>
            </li>
          
            <li>
              <a href="/blog"><img class="icone" src="imagens/blog.png"></a>
            </li>
          </ul>
        </nav>
        <center> <img src="imagens/logo.png" class="logo"> </center>
        <a href="/cadastro">
          <img src="imagens/imagem sem perfil.png" alt="Descrição da Imagem" />
        </a>
      </nav>
    </header>
    <main>
      <br>
      <!--                                        barra de pesquisa                                              -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
          <div class="search-container">
            <i class="fas fa-search search-icon"></i>
            <input type="text" class="search-box" placeholder="Buscar...">
          </div>
       <br>
       <p class="bemvindo">Bem-Víndo ao site Vintélo</p>
       <!--                                       Carrossel de banners                                              -->
      <div class="carousel-container">
        <div class="carousel-slide">
          <img src="imagens/coleçao outono.jpeg" alt="Imagem 1">
          <img src="imagens/banner primeira compra.jpeg" alt="Imagem 2">
          <img src="imagens/banner boss.jpeg" alt="Imagem 3">
        </div>
        <div class="carousel-indicators">
          <div class="active"></div>
        </div>
      </div>
       <br>
       <!--                                      Carrossel das categorias                                              -->
      <nav class="category-nav">
        <h3>Navegue por <span>categoria</span></h3>
        <br>
        <div class="carousel-container">
            <ul>
                <li><a href="/vestidos">Vestidos</a></li>
                <li><a href="/saias">Saias</a></li>
                <li><a href="/blusas">Blusas</a></li>
                <li><a href="/acessorios">Acessórios</a></li>
                <li><a href="/blusas">Calças</a></li>
                <li><a href="/acessorios">Calçados</a></li>
            </ul>
        </div>
      </nav>
         <!--                                    Seção dos produtos                                              -->
          <nav class="grid-produtos">
          <h3>Novidades</h3>
          <a href="/"><span class="ver">ver tudo</span></a> 
          </nav>
         <section class="product-grid">
          <article class="product-card">
              <a href="/produto1"><img src="imagens/vestido branco.png" alt="Vestido branco com decote"></a>
              <h2>Vestido branco com decote</h2>
              <p class="price">R$49,99</p>
              <button class="favorite"><img src="imagens/heart.png"></button>
              <button class="cart"><img src="imagens/icone sacola.png"></button>
          </article>
  
          <article class="product-card">
              <a href="/produto2"><img src="imagens/vestido roxo.png" alt="Vestido roxo de manga com decote"></a>
              <h2>Vestido roxo de manga com decote</h2>
              <p class="price">R$39,99</p>
              <button class="favorite"><img src="imagens/heart.png"></button>
              <button class="cart"><img src="imagens/icone sacola.png"></button>
          </article>
  
          <article class="product-card">
              <a href="/produto3"><img src="imagens/conjunto de blusa rosa.png" alt="Conjunto rosa de lã"></a>
              <h2>Conjunto rosa de lã</h2>
              <p class="price">R$29,99</p>
              <button class="favorite"><img src="imagens/heart.png"></button>
              <button class="cart"><img src="imagens/icone sacola.png"></button>
          </article>
  
          <article class="product-card">
              <a href="/produto4"><img src="imagens/regata branca.png" alt="Regata branca"></a>
              <h2>Regata branca</h2>
              <p class="price">R$19,99</p>
              <button class="favorite"><img src="imagens/heart.png"></button>
              <button class="cart"><img src="imagens/icone sacola.png"></button>
          </article>
      </section>
         <br>
         <br>
         <!--                                        banner de anuncio                                             -->
        <section class="ad-container">
          <article class="ad-left">
            <h1>Exemplo</h1>
            <p>de anúncio!</p>
          </article>
          <aside class="ad-right">
            <h2>Anúncio</h2>
            <p>aqui</p>
          </aside>
        </section>
         <br>
         <br>
         <!--                                        Perfil dos Brechós                                              -->
         <h2 class="titulobrecho">Encontre outros Brechós</h2>
         <br>
         <br>
         <ul class="profile-list">
           <li class="profile-item">
               <img src="imagens/brecho1.png" alt="Mayte" class="profile-image">
               <div class="profile-info">
                   <strong>Mayte</strong>
                   <span class="rating">4.8 <small>avaliação</small></span>
                   <div class="stars">★★★★★</div>
               </div>
               <a href="/perfil1"><button class="follow-button">Seguir</button></a>
           </li>
           <br>
           <br>
           <li class="profile-item">
               <img src="imagens/brecho2.png" alt="Karine" class="profile-image">
               <div class="profile-info">
                   <strong>Karine</strong>
                   <span class="rating">4.3 <small>avaliação</small></span>
                   <div class="stars">★★★★☆</div>
               </div>
               <a href="/perfil2"><button class="follow-button">Seguir</button></a>
           </li>
           <br>
           <br>
           <li class="profile-item">
               <img src="imagens/brecho3.png" alt="Coisitas" class="profile-image">
               <div class="profile-info">
                   <strong>Coisitas</strong>
                   <span class="rating">4.2 <small>avaliação</small></span>
                   <div class="stars">★★★★☆</div>
               </div>
               <a href="/perfil3"><button class="follow-button">Seguir</button></a>
           </li>
       </ul>
           <br>
           <br>
           <!--                                       banner de cadastro                                              -->
            <a href="/cadastro">  
              <center><img src="imagens/cadastro.png" class="img-responsiva"></center>
            </a>
            <br>
            <br>
            <!--                                        banner de anúncio                                              -->
            <section class="ad-container">
              <article class="ad-left">
                <h1>Exemplo</h1>
                <p>de anúncio!</p>
              </article>
              <aside class="ad-right">
                <h2>Anúncio</h2>
                <p>aqui</p>
              </aside>
            </section>
            <br>
            <br>
            <!--                                        Seção de artigos                                             -->
            <section class="artigos">
            <h3>Tendências na<span>Vintélo</span></h3>
            <br>
            <section class="carousel-2">
              <div class="carousel-container-2">
                <div class="carousel-artigos">
                  <img src="imagens/boss milão.png" alt="Desfile Boss Milão Verão">
                  <img src="imagens/boss.jpg" alt="Desfile Boss Milão Verão">
                </div>
              </div>
            </section>
              <p class="p-artigos">Confira:</p>
              <h3 class="h3-artigos">BOSS | MILÃO | VERÃO |</h3>
              <a href="/blog" class="link-preto">Ler agora</a>
            </section>   
 <!--                                                  mini cadastro                                                    -->
     <section class="newsletter">
        <h2>Fique por dentro das novidades</h2>
        <p>Informe seu e-mail e receba as novidades!</p>
        <form>
            <label>
                <input type="radio" name="news-option"> Vender
            </label>
            <label>
                <input type="radio" name="news-option"> Comprar
            </label>
            <input type="email" placeholder="E-mail*" required>
            <button type="submit">Cadastrar</button>
        </form>
    </section>
    </main>
    <!--                                                    Rodapé                                                      -->
    <footer class="footer">
      <img src="imagens/logo2.jpeg" alt="Imagem do Rodapé" class="footer-image">
      <div class="social-media">
        <p class="p-footer">Siga nossas redes sociais</p>
        <ul class="social-links">
          <li><a href="https://facebook.com" target="_blank" class="social-link"><img src="imagens/Facebook.png" alt="Facebook"></a></li>
          <li><a href="https://twitter.com" target="_blank" class="social-link"><img src="imagens/Pinterest.png" alt="Pinterest"></a></li>
          <li><a href="https://www.instagram.com/vintelobrechos" target="_blank" class="social-link"><img src="imagens/Instagram.png" alt="Instagram"></a></li>
        </ul>
      </div>
       <p class="copyright">©2024 Vintélo. Todos os direitos reservados.</p>
    </footer>
  </body>
</html>
  