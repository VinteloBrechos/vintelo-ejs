<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar Brechó - Vintélo</title>
    <link rel="stylesheet" href="css/criarbrecho.css">
</head>
<body>
    <header>
        <nav class="grid">
          <a href="/homecomprador">
            <img src="imagens/seta.png" alt="Seta Voltar">
          </a>
          <img src="imagens/logo.png" alt="Logo">
          <a href="/carrinho">
            <img src="imagens/carrinho.png" alt="Carrinho">
          </a>
        </nav>
      </header>

    <main>
        <section class="form-section">
            <h2>Crie seu brechó</h2>
            <p>Insira os dados do seu brechó</p>
            
            <div class="profile-section">
                <img src="imagens/maria.png" alt="Foto do Perfil" class="profile-img">
                <button class="edit-icon">✎</button>
            </div>
            <br>
            <div class="form-group">
                <label for="nome">Nome do brechó</label>
                <input type="text" id="nome" value="Brechó da Lourdinha" disabled>
                <span class="check-icon">✔</span>
            </div>

            <div class="form-group">
                <label for="contato">Contato</label>
                <input type="text" id="contato" value="(11) 95730-5748" disabled>
                <span class="check-icon">✔</span>
            </div>

            <div class="form-group">
                <label for="endereco">Adicionar endereço</label>
                <input type="text" id="endereco" value="Av. Paulista - São Paulo" disabled>
                <span class="check-icon">✔</span>
            </div>
            <br>
            <h3>Onde deseja receber?</h3>
            <br>
            <nav class="grid-pagamento"> 
                <img src="imagens/visa.png" class="img-pagamento">
                <p class="pagamento">Cartão</p>
                <span class="error-icon">❌</span>
            </nav>
            <br>
            <nav class="grid-pagamento">
                <img src="imagens/boleto.png" class="img-pagamento">
                <p class="pagamento">Boleto</p>
                <span class="check-icon-2">✔</span> 
            </nav>
            <br>
            <nav class="grid-pagamento">
                <button class="add-option">+</button>
                <p class="pagamento">Outra forma</p>
                <span class="check-icon-2">✔</span>
            </nav>
            
        </section>
        </main>
        <br>
        <footer>
            <a href="/homevendedor"><button class="create-button">Criar brechó</button></a>
        </footer>
    </main>
</body>
</html>
