<!DOCTYPE html>
<html>
  <meta charset="UTF-8">
  <head>
    <title>login</title>
    <link rel="stylesheet" href="css/login.css">
  </head>
  <body>

    <header>
      <nav class="grid">
        <a href="/index">
          <img src="imagens/seta.png" alt="Seta Voltar">
        </a>
        <img src="imagens/logo.png" alt="Logo">
        <a href="/carrinho">
          <img src="imagens/carrinho.png" alt="Carrinho">
        </a>
      </nav>
    </header>
    
    <main>
       <center><h2>Bem-Vindo</h2></center> 
       <center><p>Por favor insira seus dados para continuar</p></center> 
         <br>
         <br>
         <br>

        <div class="social-login">
            <a href="#" ><img src="imagens/face.jpg"></a>
            <a href="#" ><img src="imagens/insta.jpg"></a>
            <a href="#" ><img src="imagens/google.jpg"></a>
        </div>
         <br>
         <br>
         <br>
          <p class="divider">ou acesse via email</p>
          <br>
          <br>
          <form action="#" method="post">
          <div class="form-group">
          <label for="username">Nome de usuário</label>
          <input type="text" id="username" name="username" placeholder="Maria de Lourdes" required>
          </div>
          <br>
          <br>
          <div class="form-group">
          <label for="email">Endereço de email</label>
          <input type="email" id="email" name="email" placeholder="conta.sanders@exemplo.com" required>
          </div>
          <br>
          <br>
          <div class="form-group">
          <label for="password">Senha</label>
          <input type="password" id="password" name="password" placeholder="HJ@#9783kja" required>
          <p class="password-strength">Forte</p>
          </div>
          <br>
          <br>
          <div class="checkbox-group">
          <label>
          <input type="checkbox" name="stay-connected" checked>
                             Mantenha-me conectado
          </label>
          <label>
          <input type="checkbox" name="notifications" checked>
                             Receber notificações
          </label>
          <label>
          <input type="checkbox" name="terms" required>
                             Li e concordo com os <a href="#">Termos de Uso</a>
          </label>
          </div>
                <br>
                <br>
                <br>
            </div><button type="submit" class="submit-btn"><a href="/comprador">Cadastrar-se</a></button>
        </form>
    </div>
            <br>
            <br>

    </main>

      <!-- Rodapé -->
    <footer class="footer">
      <img src="imagens/logo2.jpeg" alt="Imagem do Rodapé" class="footer-image">
      <div class="social-media">
        <p>Siga nossas redes sociais</p>
        <ul class="social-links">
          <li><a href="https://facebook.com" target="_blank" class="social-link"><img src="imagens/icone do face.jpeg" alt="Facebook"></a></li>
          <li><a href="https://twitter.com" target="_blank" class="social-link"><img src="imagens/icone do twitter.jpeg" alt="Twitter"></a></li>
          <li><a href="https://www.instagram.com/vintelobrechos" target="_blank" class="social-link"><img src="imagens/icone do insta.jpeg" alt="Instagram"></a></li>
        </ul>
      </div>
       <p class="copyright">©2024 Vintélo. Todos os direitos reservados.</p>
    </footer>

</body>
</html>