<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Favoritos</title>
    <link rel="stylesheet" href="css/favoritos.css">
</head>
<body>

    <!-- Cabeçalho -->
    <header>
        <nav class="grid">
          <a href="/index">
            <img src="imagens/seta.png" alt="Seta Voltar">
          </a>
          <img src="imagens/logo.png" alt="Logo">
          <a href="/cadastro">
            <img src="imagens/icone sem cadastro.png" alt="Carrinho">
          </a>
        </nav>
      </header>

    <!-- Lista de Produtos -->
  <main>
        <center><img src="imagens/favoritos.png" class="img-responsiva"></center>
        <!-- Informações de lista -->
        <section class="list-info">
            <p> Favorite uma peça</p>
        </section>
    <main class="product-list">
        <article class="product">
            <img src="imagens/conjunto.png" alt="Saia Branca">
            <p>Saia Branca</p>
            <p>R$25,00</p>
        </article>

        <article class="product">
            <img src="imagens/saia preta brilhante.png" alt="Saia Preta">
            <p>Saia Preta Com Brilho</p>
            <p>R$30,00</p>
        </article>

        <article class="product">
            <img src="imagens/saia marrom.png" alt="Saia Marrom">
            <p>Saia De Veludo Marrom</p>
            <p>R$25,00</p>
        </article>

        <article class="product">
            <img src="imagens/calça reta.png" alt="Calça Jeans">
            <p>Calça Reta Jeans Clara</p>
            <p>R$49,99</p>
        </article>

        <article class="product">
            <img src="imagens/saia preta brilhante.png" alt="Conjunto Preto">
            <p>Conjunto saia preta c/ brilho + Top preto</p>
            <p>R$57,00</p>
        </article>

        <article class="product">
            <img src="imagens/vestido pink.png" alt="Vestido Rosa">
            <p>Vestido rosa longo</p>
            <p>R$15,00</p>
        </article>
    </main>

    <!-- Botão de Ver Mais -->
    <nav class="load-more">
        <button>Ver mais</button>
    </nav>

   </main>
   <!--                                                    Rodapé                                                      -->
   <footer class="footer">
    <img src="imagens/logo2.jpeg" alt="Imagem do Rodapé" class="footer-image">
    <div class="social-media">
      <p>Siga nossas redes sociais</p>
      <ul class="social-links">
        <li><a href="https://facebook.com" target="_blank" class="social-link"><img src="imagens/icone do face.jpeg" alt="Facebook"></a></li>
        <li><a href="https://twitter.com" target="_blank" class="social-link"><img src="imagens/icone do twitter.jpeg" alt="Twitter"></a></li>
        <li><a href="https://www.instagram.com/vintelobrechos" target="_blank" class="social-link"><img src="imagens/icone do insta.jpeg" alt="Instagram"></a></li>
      </ul>
    </div>
     <p class="copyright">©2024 Vintélo. Todos os direitos reservados.</p>
  </footer>

</body>
</html>
