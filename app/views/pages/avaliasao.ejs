<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Avaliações</title>
    <link rel="stylesheet" href="css/avaliasao.css">
</head>
<body>
    <header>
        <nav>
            <a href="/perfil1">
                <img src="imagens/seta.png" class="Seta-voltar">
              </a>
            <h1 class="titulo-header">Avaliações</h1>
            <button class="profile-button">
                <img src="imagens/maria.png" alt="Perfil">
            </button>
        </nav>
    </header>

    <section class="summary">
        <p><strong class="avaliaçao">245 avaliações<br>4.8<span class="stars">★★★★☆</span></strong></p>
        <button class="add-review"><img src="imagens/editar.png" class="editar"> Adicione uma avaliação</button>
