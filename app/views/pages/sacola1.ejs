<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Sacola</title>
  <link rel="stylesheet" href="css/sacola.css">
</head>
<body>
  <div class="container">
    <header>
      <nav class="grid">
        <a href="/index">
          <img src="imagens/seta.png" alt="Seta Voltar">
        </a>
        <img src="imagens/logo.png" alt="Logo">
        <a href="/carrinho">
          <img src="imagens/carrinho.png" alt="Carrinho">
        </a>
      </nav>
    </header>

    <section class="cart-item">
      <img src="vestido-branco.jpg" alt="Vestido Branco Longo" class="item-image">
      <div class="item-details">
        <h2>Vestido Branco Longo</h2>
        <p class="price">R$49,90</p>
        <button class="delete-button">🗑️</button>
      </div>
    </section>

    <section class="order-info">
      <h3>Informações do pedido</h3>
      <div class="order-details">
        <p>Subtotal <span>R$49,99</span></p>
        <p>Frete <span>R$10,00</span></p>
        <p>Desconto <span>R$0,00</span></p>
        <p>Total <span>R$59,99</span></p>
      </div>
    </section>

    <section class="coupon">
      <h3>Inserir cupom de desconto</h3>
      <input type="text" placeholder="Digite o cupom">
      <button class="insert-button">Inserir</button>
    </section>

    <section class="add-more">
      <h3>Adicione mais ao carrinho</h3>
      <div class="product-list">
        <div class="product-card">
          <img src="saia-branca.jpg" alt="Saia Branca">
          <p>Saia Branca</p>
          <p class="price">R$25,00</p>
        </div>
        <div class="product-card">
          <img src="saia-preta.jpg" alt="Saia Preta">
          <p>Saia Preta</p>
          <p class="price">R$30,00</p>
        </div>
        <div class="product-card">
          <img src="saia-de-veludo.jpg" alt="Saia de Veludo">
          <p>Saia de Veludo</p>
          <p class="price">R$25,00</p>
        </div>
      </div>
    </section>

    <footer>
      <button class="finalize-button">Finalizar compra</button>
    </footer>
  </div>
</body>
</html>
